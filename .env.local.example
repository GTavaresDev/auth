AUTH_GOOGLE_ID="your-google-client-id"
AUTH_GOOGLE_SECRET="your-google-client-secret"
AUTH_SECRET="generate-a-random-secret"

# Local Docker Postgres
DATABASE_URL="postgresql://auth:auth@localhost:5432/auth_local?schema=public"
DIRECT_URL="postgresql://auth:auth@localhost:5432/auth_local?schema=public"
